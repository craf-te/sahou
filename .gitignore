# Rust build artifacts
/target

# Python runtime (runtimes/py)
runtimes/py/.venv/
**/__pycache__/
*.egg-info/
.pytest_cache/
# build artifacts that `maturin develop` (editable install) drops inside the python source
runtimes/py/python/sahou/_core.pyd
runtimes/py/python/sahou/_core.so
runtimes/py/python/sahou/*.pdb

# demo example (file: dependency on runtimes/ts + generated IR)
# The IR (whole descriptor.json) is a generated artifact, so it is ignored. The stub artifacts
# (gen/<node>/sahou_stub.*) are committed as freshness-guard fixtures and living examples, so they are NOT ignored.
examples/demo/runtime/gen/descriptor.json
examples/demo/runtime/**/node_modules/

# GUI (gui/): dependencies, build outputs, and wasm-pack artifacts are generated, so they are ignored (.gitkeep keeps just the empty dist container)
gui/node_modules/
gui/dist/*
!gui/dist/.gitkeep
gui/src/core-wasm/

# CLI embeds the built GUI from cli/gui-dist (populated by `just gui-embed`); keep only the folder.
cli/gui-dist/*
!cli/gui-dist/.gitkeep
