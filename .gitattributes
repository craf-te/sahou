# Shell scripts are always checked out with LF (never converted to CRLF, even under Windows autocrlf=true).
# If they became CRLF, the `#!/usr/bin/env bash` shebang would break under Git Bash and they could not run.
*.sh text eol=lf

# Type stubs generated by `sahou gen` are always checked out with LF (the core gen_stub emits `\n`).
# If autocrlf=true converted them to CRLF, the stub_freshness test (cli/tests/stub_freshness.rs) that
# verifies byte-equality between the committed stub and a gen_stub regeneration would fail
# on a fresh checkout (CI / other machines).
sahou_stub.* text eol=lf
